create table public.cart_items (
  id uuid not null default gen_random_uuid (),
  user_id uuid not null,
  product_id text not null,
  product_name text null,
  price bigint null,
  quantity integer null default 1,
  created_at timestamp with time zone null default now(),
  pages integer null default 1,
  constraint cart_items_pkey primary key (id),
  constraint cart_items_user_id_fkey foreign KEY (user_id) references auth.users (id)
) TABLESPACE pg_default;

create table public.messages (
  id uuid not null default gen_random_uuid (),
  sender_id uuid null,
  content text not null,
  created_at timestamp with time zone null default now(),
  receiver_id uuid null,
  constraint messages_pkey primary key (id),
  constraint messages_receiver_id_fkey foreign KEY (receiver_id) references profiles (id),
  constraint messages_sender_id_fkey foreign KEY (sender_id) references profiles (id)
) TABLESPACE pg_default;

create table public.order_items (
  id uuid not null default gen_random_uuid (),
  order_id uuid null,
  product_name text not null,
  price bigint not null,
  quantity integer not null,
  design_url text null,
  pages integer null default 1,
  constraint order_items_pkey primary key (id),
  constraint order_items_order_id_fkey foreign KEY (order_id) references orders (id) on delete CASCADE
) TABLESPACE pg_default;

create table public.orders (
  id uuid not null default gen_random_uuid (),
  order_number serial not null,
  user_id uuid not null,
  total_amount bigint not null,
  payment_status text null default 'pending'::text,
  order_status text null default 'pending'::text,
  payment_proof_url text null,
  created_at timestamp with time zone null default now(),
  shipping_method text null default 'Pick Up'::text,
  constraint orders_pkey primary key (id),
  constraint orders_user_id_fkey foreign KEY (user_id) references profiles (id) on delete CASCADE,
  constraint orders_order_status_check check (
    (
      order_status = any (
        array[
          'pending'::text,
          'Diterima'::text,
          'Dibuat'::text,
          'Selesai'::text,
          'Dikirim'::text,
          'Dibatalkan'::text
        ]
      )
    )
  ),
  constraint orders_payment_status_check check (
    (
      payment_status = any (
        array[
          'pending'::text,
          'waiting_confirmation'::text,
          'confirmed'::text,
          'rejected'::text
        ]
      )
    )
  ),
  constraint orders_shipping_method_check check (
    (
      shipping_method = any (array['Ship'::text, 'Pick Up'::text])
    )
  )
) TABLESPACE pg_default;

create table public.profiles (
  id uuid not null,
  full_name text null,
  role text null default 'customer'::text,
  address text null,
  phone_number text null,
  created_at timestamp with time zone null default timezone ('utc'::text, now()),
  username text null,
  email text null,
  street text null,
  village text null,
  district text null,
  province text null,
  city text null,
  constraint profiles_pkey primary key (id),
  constraint profiles_username_key unique (username),
  constraint profiles_id_fkey foreign KEY (id) references auth.users (id) on delete CASCADE,
  constraint profiles_role_check check (
    (
      role = any (array['owner'::text, 'customer'::text])
    )
  )
) TABLESPACE pg_default;

